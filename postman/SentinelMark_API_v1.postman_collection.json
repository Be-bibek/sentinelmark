{
  "info": {
    "name": "SentinelMark API v1",
    "description": "Public API Contract for SentinelMark Trust Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Events",
      "item": [
        {
          "name": "Evaluate Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_slug\": \"stellarflow\",\n  \"api_version\": \"v1\",\n  \"protocol_version\": \"1.0\",\n  \"sdk_version\": \"1.0.0\",\n  \"event_type\": \"transfer\",\n  \"timestamp\": \"2026-06-30T00:00:00Z\",\n  \"payload\": {\n    \"amount\": 500\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "events"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Developer Portal",
      "item": [
        {
          "name": "List API Keys",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/api-keys",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "api-keys"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "sm_live_123",
      "type": "string"
    }
  ]
}
