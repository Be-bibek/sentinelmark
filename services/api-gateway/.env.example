# SentinelMark v2 — API Gateway Environment Variables

# Server
PORT=8080
ENVIRONMENT=development
RUST_LOG=info

# Database (required)
DATABASE_URL=postgres://user:password@localhost:5432/sentinelmark

# Authentication
# Options: disabled | jwt | apikey
AUTH_MODE=disabled
JWT_SECRET=your_secret_key_here_change_in_production

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
